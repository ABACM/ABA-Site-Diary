{
  "cli": {
    "version": ">= 10.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "EXPO_NO_LOCKFILE_CHECK": "1",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_NO_LOCKFILE_CHECK": "1"
      }
    }
  }
}
